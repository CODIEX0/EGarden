<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RemovePlantFragment"
    android:orientation="vertical"
    android:background="@color/background"
    android:weightSum="2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20sp"
            android:layout_marginBottom="12sp"
            android:text="Plant"
            android:fontFamily="sans-serif-condensed-light"
            android:textColor="@color/buttonColor"
            android:textSize="70dp"
            android:textFontWeight="400"
            android:textStyle="bold" />

        <View
            android:layout_width="350dp"
            android:layout_height="1sp"
            android:layout_marginBottom="11sp"
            android:background="@color/buttonColor" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAME: "
                android:fontFamily="sans-serif-condensed-light"
                android:textColor="@color/buttonColor"
                android:textSize="28dp"
                android:textStyle="bold"
                android:layout_marginRight="8sp"/>

            <TextView
                android:id="@+id/txtPlantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:text="--plant name--"
                android:fontFamily="sans-serif-condensed-light"
                android:textColor="@color/buttonColor"
                android:textSize="26dp"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPECIES: "
                android:fontFamily="sans-serif-condensed-light"
                android:textColor="@color/buttonColor"
                android:textSize="28dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtPlantSpecies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8sp"
                android:text="--plant species--"
                android:fontFamily="sans-serif-condensed-light"
                android:textColor="@color/buttonColor"
                android:textSize="26dp"
                android:gravity="center"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/imgPlantImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginBottom="11sp"
            android:scaleType="centerCrop"
            tools:background="@android:drawable/ic_menu_gallery" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/buttonColor"
                android:drawableEnd="@android:drawable/ic_menu_delete"
                android:text="Delete"
                android:textColor="@color/black"
                android:textSize="19dp"
                android:layout_marginRight="50dp"/>

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/buttonColor"
                android:drawableEnd="@android:drawable/ic_menu_edit"
                android:text="Edit"
                android:textColor="@color/black"
                android:textSize="19dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.appcompat.widget.LinearLayoutCompat>